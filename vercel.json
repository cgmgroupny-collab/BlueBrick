{
  "functions": {
    "api/chat.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 10
    },
    "api/subscribe.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 10
    },
    "api/track.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 5
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/index.html",
      "destination": "/"
    }
  ]
}
