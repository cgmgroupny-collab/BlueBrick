{
  "functions": {
    "api/chat.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 10
    },
    "api/subscribe.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
