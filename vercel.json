{
  "functions": {
    "api/chat.py":                    { "runtime": "@vercel/python@4.5.0", "maxDuration": 10 },
    "api/subscribe.py":               { "runtime": "@vercel/python@4.5.0", "maxDuration": 10 },
    "api/track.py":                   { "runtime": "@vercel/python@4.5.0", "maxDuration": 5  },
    "api/create-checkout-session.js": { "maxDuration": 10 },
    "api/stripe-webhook.js":          { "maxDuration": 15 },
    "api/get-customer-portal.js":     { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/book",          "destination": "/book/index.html" },
    { "source": "/dashboard",     "destination": "/dashboard/index.html" },
    { "source": "/admin",         "destination": "/admin/bookings.html" },
    { "source": "/admin/bookings","destination": "/admin/bookings.html" },
    { "source": "/legal/terms",   "destination": "/legal/terms/index.html" },
    { "source": "/index.html",    "destination": "/" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|woff2|woff|png|jpg|jpeg|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    }
  ]
}
